  {"question": "Sales per category each year.", "sql": "SELECT d.year, p.product_category, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY d.year, p.product_category ORDER BY d.year, sales DESC"},
  {"question": "Yearly performance by product category.", "sql": "SELECT d.year, p.product_category, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY d.year, p.product_category ORDER BY d.year"},
  {"question": "Annual revenue per state.", "sql": "SELECT d.year, s.store_branch_state, SUM(f.transaction_sale_amount) AS revenue FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id GROUP BY d.year, s.store_branch_state ORDER BY d.year, revenue DESC"},
  {"question": "Year-over-year sales by branch state.", "sql": "SELECT d.year, s.store_branch_state, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id GROUP BY d.year, s.store_branch_state ORDER BY d.year"},
  {"question": "Channel performance per year.", "sql": "SELECT d.year, j.junk_sales_channel, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id GROUP BY d.year, j.junk_sales_channel ORDER BY d.year"},
  {"question": "Annual payment method usage.", "sql": "SELECT d.year, j.junk_payment_method, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id GROUP BY d.year, j.junk_payment_method ORDER BY d.year, sales DESC"},
  {"question": "Sales channel and category cross-table.", "sql": "SELECT j.junk_sales_channel, p.product_category, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY j.junk_sales_channel, p.product_category ORDER BY sales DESC"},
  {"question": "Payment method by category breakdown.", "sql": "SELECT j.junk_payment_method, p.product_category, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY j.junk_payment_method, p.product_category"},
  {"question": "Shipping method versus product category sales matrix.", "sql": "SELECT sh.shipping_method, p.product_category, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_shippings sh ON f.shipping_surr_id = sh.shipping_surr_id JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY sh.shipping_method, p.product_category"},
  {"question": "Best customers in Germany during 2024.", "sql": "SELECT c.customer_firstname, c.customer_lastname, SUM(f.transaction_sale_amount) AS spending FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_customers_scd c ON f.customer_surr_id = c.customer_surr_id AND c.is_active = TRUE JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key WHERE c.customer_country = 'Germany' AND d.year = 2024 GROUP BY c.customer_src_id, c.customer_firstname, c.customer_lastname ORDER BY spending DESC LIMIT 5"},
  {"question": "Top 10 buyers from France in 2023.", "sql": "SELECT c.customer_firstname, c.customer_lastname, SUM(f.transaction_sale_amount) AS spending FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_customers_scd c ON f.customer_surr_id = c.customer_surr_id AND c.is_active = TRUE JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key WHERE c.customer_country = 'France' AND d.year = 2023 GROUP BY c.customer_src_id, c.customer_firstname, c.customer_lastname ORDER BY spending DESC LIMIT 10"},
  {"question": "Sales by employees who work in Texas.", "sql": "SELECT e.employee_firstname, e.employee_lastname, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.v_employees_public e ON f.employee_surr_id = e.employee_surr_id WHERE e.employee_store_branch_state = 'Tx' GROUP BY e.employee_src_id, e.employee_firstname, e.employee_lastname ORDER BY sales DESC"},
  {"question": "California staff sales totals.", "sql": "SELECT e.employee_firstname, e.employee_lastname, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.v_employees_public e ON f.employee_surr_id = e.employee_surr_id WHERE e.employee_store_branch_state = 'Ca' GROUP BY e.employee_src_id, e.employee_firstname, e.employee_lastname ORDER BY sales DESC"},
  {"question": "Profit per state in fiscal 2024.", "sql": "SELECT s.store_branch_state, SUM(f.transaction_gross_profit) AS profit FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key WHERE d.year = 2024 GROUP BY s.store_branch_state ORDER BY profit DESC"},
  {"question": "Margin per category in 2023.", "sql": "SELECT p.product_category, AVG(f.transaction_profit_margin) AS avg_margin FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key WHERE d.year = 2023 GROUP BY p.product_category"},

  {"question": "Sales when discount exceeded 25%.", "sql": "SELECT SUM(f.transaction_sale_amount) AS discounted_sales FROM bl_dm.fct_transactions_dd f WHERE f.transaction_discount_pct > 25"},
  {"question": "Revenue from heavily discounted orders (>30%).", "sql": "SELECT SUM(f.transaction_sale_amount) AS revenue FROM bl_dm.fct_transactions_dd f WHERE f.transaction_discount_pct > 30"},
  {"question": "Number of orders with no discount applied.", "sql": "SELECT COUNT(*) AS no_discount_orders FROM bl_dm.fct_transactions_dd f WHERE f.transaction_discount_pct = 0"},
  {"question": "Transactions with discount between 10 and 20 percent.", "sql": "SELECT COUNT(*) AS num_transactions FROM bl_dm.fct_transactions_dd f WHERE f.transaction_discount_pct BETWEEN 10 AND 20"},
  {"question": "Average sale amount when discount is over 15%.", "sql": "SELECT AVG(f.transaction_sale_amount) AS avg_sale FROM bl_dm.fct_transactions_dd f WHERE f.transaction_discount_pct > 15"},
  {"question": "Big-ticket transactions over 1000 dollars.", "sql": "SELECT COUNT(*) AS big_transactions FROM bl_dm.fct_transactions_dd f WHERE f.transaction_sale_amount > 1000"},
  {"question": "Sales above 500 in value.", "sql": "SELECT COUNT(*) AS num_sales FROM bl_dm.fct_transactions_dd f WHERE f.transaction_sale_amount > 500"},
  {"question": "Transactions where quantity sold was greater than 5.", "sql": "SELECT COUNT(*) AS bulk_orders FROM bl_dm.fct_transactions_dd f WHERE f.transaction_quantity_sold > 5"},
  {"question": "Bulk orders revenue (qty > 10).", "sql": "SELECT SUM(f.transaction_sale_amount) AS bulk_revenue FROM bl_dm.fct_transactions_dd f WHERE f.transaction_quantity_sold > 10"},
  {"question": "Transactions with negative profit (losses).", "sql": "SELECT COUNT(*) AS loss_transactions FROM bl_dm.fct_transactions_dd f WHERE f.transaction_gross_profit < 0"},

  {"question": "Categories selling more than 1000 units total.", "sql": "SELECT p.product_category, SUM(f.transaction_quantity_sold) AS units FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY p.product_category HAVING SUM(f.transaction_quantity_sold) > 1000"},
  {"question": "Branches with revenue above 100000.", "sql": "SELECT s.store_branch_city, SUM(f.transaction_sale_amount) AS revenue FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id GROUP BY s.store_branch_city HAVING SUM(f.transaction_sale_amount) > 100000"},
  {"question": "Customers who have spent over 5000.", "sql": "SELECT c.customer_firstname, c.customer_lastname, SUM(f.transaction_sale_amount) AS spending FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_customers_scd c ON f.customer_surr_id = c.customer_surr_id AND c.is_active = TRUE GROUP BY c.customer_src_id, c.customer_firstname, c.customer_lastname HAVING SUM(f.transaction_sale_amount) > 5000 ORDER BY spending DESC"},
  {"question": "Employees with more than 100 transactions handled.", "sql": "SELECT e.employee_firstname, e.employee_lastname, COUNT(*) AS num_transactions FROM bl_dm.fct_transactions_dd f JOIN bl_dm.v_employees_public e ON f.employee_surr_id = e.employee_surr_id GROUP BY e.employee_src_id, e.employee_firstname, e.employee_lastname HAVING COUNT(*) > 100 ORDER BY num_transactions DESC"},
  {"question": "Product categories with average margin above 0.3.", "sql": "SELECT p.product_category, AVG(f.transaction_profit_margin) AS avg_margin FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY p.product_category HAVING AVG(f.transaction_profit_margin) > 0.3"},

  {"question": "Information about a supplier — show all suppliers in our database.", "sql": "SELECT s.supplier_name, s.supplier_location FROM bl_dm.dm_suppliers s ORDER BY s.supplier_name"},
  {"question": "Sales attributed to each supplier.", "sql": "SELECT s.supplier_name, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_suppliers s ON f.supplier_surr_id = s.supplier_surr_id GROUP BY s.supplier_name ORDER BY sales DESC"},
  {"question": "Top 5 suppliers by total sales.", "sql": "SELECT s.supplier_name, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_suppliers s ON f.supplier_surr_id = s.supplier_surr_id GROUP BY s.supplier_name ORDER BY sales DESC LIMIT 5"},
  {"question": "Number of products supplied per supplier.", "sql": "SELECT s.supplier_name, COUNT(DISTINCT f.product_surr_id) AS products FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_suppliers s ON f.supplier_surr_id = s.supplier_surr_id GROUP BY s.supplier_name"},

  {"question": "Average margin earned during weekends.", "sql": "SELECT AVG(f.transaction_profit_margin) AS weekend_margin FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key WHERE d.is_weekend = TRUE"},
  {"question": "Top product per state — overall best seller in California.", "sql": "SELECT p.product_name, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id WHERE s.store_branch_state = 'Ca' GROUP BY p.product_name ORDER BY sales DESC LIMIT 1"},
  {"question": "Best-selling category in Texas.", "sql": "SELECT p.product_category, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id WHERE s.store_branch_state = 'Tx' GROUP BY p.product_category ORDER BY sales DESC LIMIT 1"},
  {"question": "How does Q4 2024 compare to Q4 2023 in sales?", "sql": "SELECT d.year, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key WHERE d.quarter = 4 AND d.year IN (2023, 2024) GROUP BY d.year ORDER BY d.year"},
  {"question": "Year over year sales growth — show me each year's total.", "sql": "SELECT d.year, SUM(f.transaction_sale_amount) AS yearly_sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key GROUP BY d.year ORDER BY d.year"},
  {"question": "Average discount per category.", "sql": "SELECT p.product_category, AVG(f.transaction_discount_pct) AS avg_discount FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id GROUP BY p.product_category"},
  {"question": "Discount rate by sales channel.", "sql": "SELECT j.junk_sales_channel, AVG(f.transaction_discount_pct) AS avg_discount FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id GROUP BY j.junk_sales_channel"},
  {"question": "Returned orders broken down by category.", "sql": "SELECT p.product_category, COUNT(*) AS returns FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_products p ON f.product_surr_id = p.product_surr_id JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id WHERE j.junk_shipment_status = 'Returned' GROUP BY p.product_category ORDER BY returns DESC"},
  {"question": "Cancelled orders per state.", "sql": "SELECT s.store_branch_state, COUNT(*) AS cancellations FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id WHERE j.junk_shipment_status = 'Cancelled' GROUP BY s.store_branch_state"},
  {"question": "Express shipping share of total revenue.", "sql": "SELECT SUM(CASE WHEN sh.shipping_method = 'Express Shipping' THEN f.transaction_sale_amount ELSE 0 END) AS express_revenue, SUM(f.transaction_sale_amount) AS total_revenue FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_shippings sh ON f.shipping_surr_id = sh.shipping_surr_id"},
  {"question": "Compare in-store vs online channel revenue.", "sql": "SELECT j.junk_sales_channel, SUM(f.transaction_sale_amount) AS revenue FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id WHERE j.junk_sales_channel IN ('In-Store', 'Website', 'Mobile App') GROUP BY j.junk_sales_channel"},
  {"question": "Find customers who bought in 2023 but not 2024.", "sql": "SELECT DISTINCT c.customer_firstname, c.customer_lastname FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_customers_scd c ON f.customer_surr_id = c.customer_surr_id AND c.is_active = TRUE JOIN bl_dm.dim_dates d ON f.event_date_key = d.date_key WHERE d.year = 2023 AND c.customer_src_id NOT IN (SELECT c2.customer_src_id FROM bl_dm.fct_transactions_dd f2 JOIN bl_dm.dm_customers_scd c2 ON f2.customer_surr_id = c2.customer_surr_id JOIN bl_dm.dim_dates d2 ON f2.event_date_key = d2.date_key WHERE d2.year = 2024)"}
]