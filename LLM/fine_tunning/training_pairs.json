  {"question": "Mobile App revenue.", "sql": "SELECT SUM(f.transaction_sale_amount) AS revenue FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id WHERE j.junk_sales_channel = 'Mobile App'"},
