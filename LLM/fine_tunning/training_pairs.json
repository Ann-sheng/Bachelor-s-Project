  {"question": "USD revenue total.", "sql": "SELECT SUM(f.transaction_sale_amount) AS revenue FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id WHERE j.junk_currency_paid = 'USD'"},
  {"question": "Counts grouped by shipment status.", "sql": "SELECT j.junk_shipment_status, COUNT(*) AS num_transactions FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id GROUP BY j.junk_shipment_status"},
  {"question": "How many orders are still pending?", "sql": "SELECT COUNT(*) AS pending_count FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_junk_transactions j ON f.junk_surr_id = j.junk_surr_id WHERE j.junk_shipment_status = 'Pending'"},
