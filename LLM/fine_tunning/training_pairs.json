  {"question": "How much did Florida stores sell?", "sql": "SELECT SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id WHERE s.store_branch_state = 'Fl'"},
