  {"question": "Most profitable city branch.", "sql": "SELECT s.store_branch_city, SUM(f.transaction_gross_profit) AS profit FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_store_branches s ON f.store_branch_surr_id = s.store_branch_surr_id GROUP BY s.store_branch_city ORDER BY profit DESC LIMIT 1"},
