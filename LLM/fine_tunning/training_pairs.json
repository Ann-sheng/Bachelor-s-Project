  {"question": "Carrier-level sales breakdown.", "sql": "SELECT sh.shipping_carrier, SUM(f.transaction_sale_amount) AS sales FROM bl_dm.fct_transactions_dd f JOIN bl_dm.dm_shippings sh ON f.shipping_surr_id = sh.shipping_surr_id GROUP BY sh.shipping_carrier"},
