# MinIO object storage configuration (used as source for ETL ingestion)
CLOUD_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=DnD_Minio_key
MINIO_SECRET_KEY=DnD_Minio_PassKey
MINIO_BUCKET=dnd-sales-raw # Source bucket for parquet ingestion pipeline

# PostgreSQL data warehouse connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dnd_sales
DB_USER=postgres
DB_PASSWORD=new_password
# Optional admin credentials (only used for creation)
ADMIN_USER=postgres
ADMIN_PASSWORD=new_password

# Local paths for data generation / staging files
DATA_INITIAL_DIR=data/initial
DATA_INCREMENTAL_DIR=data/incremental
DATA_REF_DIR=data/reference
LOCAL_TEMP_DIR=/tmp Temporary storage for downloaded parquet files

# Deterministic seed values for reproducible synthetic data generation
SEED_INITIAL=42
SEED_INCREMENTAL=99





